# =============================================================================
# oxi.email Configuration
# =============================================================================
# Copy this file to .env and customize for your setup.
# All values shown are defaults (used when the variable is unset).

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0                    # Bind address
PORT=3001                       # HTTP port

# -----------------------------------------------------------------------------
# Mail Server (IMAP)
# -----------------------------------------------------------------------------
IMAP_HOST=                      # IMAP server hostname (required)
IMAP_PORT=993                   # IMAP port (993 for TLS, 143 for STARTTLS)

# -----------------------------------------------------------------------------
# Mail Server (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=                      # SMTP server hostname (required)
SMTP_PORT=587                   # SMTP port (587 for STARTTLS, 465 for TLS)

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
TLS_ENABLED=true                # Enable TLS for mail connections
SESSION_TIMEOUT_HOURS=24        # Session expiry in hours (sliding window)

# Optional: path to a PEM certificate to add to the in-process TLS trust store.
# Use this when your mail server uses a self-signed cert not in the system CA
# bundle. No system-wide changes are made - only oxi trusts the cert.
# TLS_CA_CERT_PATH=

# Optional: TCP address to connect to for IMAP/SMTP, overriding the hostname.
# Useful when the server cannot reach its own public IP from inside (hairpin NAT).
# The IMAP_HOST / SMTP_HOST values are still used for TLS SNI and display.
# IMAP_CONNECT_HOST=
# SMTP_CONNECT_HOST=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
DATA_DIR=/data                  # Persistent data directory (SQLite + Tantivy indexes)
STATIC_DIR=/app/static          # Frontend static files directory

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=info                   # Log level (trace, debug, info, warn, error)
