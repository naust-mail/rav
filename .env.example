# =============================================================================
# oxi.email Configuration
# =============================================================================
# Copy this file to .env and customize for your setup.
# All values shown are defaults (used when the variable is unset).

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0                    # Bind address
PORT=3001                       # HTTP port

# -----------------------------------------------------------------------------
# Mail Server (IMAP)
# -----------------------------------------------------------------------------
IMAP_HOST=                      # IMAP server hostname (required)
IMAP_PORT=993                   # IMAP port (993 for TLS, 143 for STARTTLS)

# -----------------------------------------------------------------------------
# Mail Server (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=                      # SMTP server hostname (required)
SMTP_PORT=587                   # SMTP port (587 for STARTTLS, 465 for TLS)

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
TLS_ENABLED=true                # Enable TLS for mail connections
SESSION_TIMEOUT_HOURS=24        # Session expiry in hours (sliding window)

# Optional: path to a PEM certificate to add to the in-process TLS trust store.
# Use this when your mail server uses a self-signed cert not in the system CA
# bundle. No system-wide changes are made - only oxi trusts the cert.
# TLS_CA_CERT_PATH=

# Optional: TCP address to connect to for IMAP/SMTP, overriding the hostname.
# Useful when the server cannot reach its own public IP from inside (hairpin NAT).
# The IMAP_HOST / SMTP_HOST values are still used for TLS SNI and display.
# IMAP_CONNECT_HOST=
# SMTP_CONNECT_HOST=

# -----------------------------------------------------------------------------
# Spam filtering (rspamd)
# -----------------------------------------------------------------------------
# Optional: Uncomment to enable spam/ham reporting. The backend will POST raw
# message bytes to rspamd's learn API when the user marks a message as junk or
# not junk.
# On Mail-in-a-Box the default URL is always http://127.0.0.1:11334.
# RSPAMD_URL=http://127.0.0.1:11334

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
DATA_DIR=/data                  # Persistent data directory (SQLite + Tantivy indexes)
STATIC_DIR=/app/static          # Frontend static files directory

# -----------------------------------------------------------------------------
# Reverse Proxy
# -----------------------------------------------------------------------------
# When running behind nginx, Apache, Caddy, or any other reverse proxy, set
# TRUSTED_PROXIES to the proxy's IP address or subnet in CIDR notation.
# Comma-separate multiple entries: "127.0.0.1/32,10.0.0.5/32"
#
# When set, X-Real-IP and X-Forwarded-For headers are trusted only if the TCP
# connection comes from one of these addresses. When unset (standalone mode),
# forwarded headers are ignored and the raw socket peer address is used.
#
# Common values:
#   Local proxy (bare metal):  TRUSTED_PROXIES=127.0.0.1/32
#   Docker (MIAB oxi-internal): TRUSTED_PROXIES=172.29.0.0/29
# TRUSTED_PROXIES=

# -----------------------------------------------------------------------------
# Link Proxy
# -----------------------------------------------------------------------------
# When enabled, all http(s) links in rendered emails are rewritten to pass
# through /api/v1/link before reaching the destination. This strips the
# Referer header (destination never sees your oxi hostname) and logs clicks.
# A signing key is auto-generated in DATA_DIR/link_proxy.key on first run.
# LINK_PROXY_ENABLED=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=info                   # Log level (trace, debug, info, warn, error)
